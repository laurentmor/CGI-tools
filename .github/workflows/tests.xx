name: CI + Release Please
env:
  # Important: force JavaScript actions to use Node 24 (required for release-please v4)
    FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

permissions:
  contents: write
  pull-requests: write
  issues: write

# -------------------------------------------------------------------
jobs:

  # =========================
  # 🧪 TESTS + COVERAGE
  # =========================
  test:
    name: Tests & Coverage
    runs-on: ubuntu-latest

    strategy:
      matrix:
        python-version: ["3.10", "3.11", "3.12"]

    defaults:
      run:
        working-directory: XMLExtractor-1.2

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: ${{ matrix.python-version }}
          cache: 'pip'   # 🔥 speed up

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install pytest pytest-cov pyzipper

      - name: Run tests
        run: |
          pytest tests/ \
            --cov=xml_extractor \
            --cov=decorators \
            --cov-report=xml \
            --cov-report=term

      # ✅ FIX IMPORTANT: path relatif au working-directory
      - name: Upload coverage to Codecov
        if: matrix.python-version == '3.12'
        uses: codecov/codecov-action@v4
        with:
          files: coverage.xml   # 🔥 corrigé
          fail_ci_if_error: true

  
  
  # =========================
  # 📝 ADD SPDX LICENSE HEADERS
  # =========================
  license:
    name: Add SPDX License Headers
    runs-on: ubuntu-latest
    needs: test
    if: github.event_name == 'push'

    steps:
      - uses: actions/checkout@v4

      - name: Add SPDX headers
        run: |
          for file in $(find XMLExtractor-1.2 -name "*.py"); do
            if ! grep -q "SPDX-License-Identifier" "$file"; then
              echo "Updating $file"

              # Préserver shebang si présent
              first_line=$(head -n 1 "$file")

              if [[ "$first_line" == "#!"* ]]; then
                tail -n +2 "$file" > tmpfile
                echo "# SPDX-License-Identifier: MIT" > "$file"
                echo "# SPDX-FileCopyrightText: 2026 Laurent Morissette" >> "$file"
                echo "" >> "$file"
                echo "$first_line" >> "$file"
                cat tmpfile >> "$file"
                rm tmpfile
              else
                tmpfile=$(mktemp)
                echo "# SPDX-License-Identifier: MIT" > "$tmpfile"
                echo "# SPDX-FileCopyrightText: 2026 Laurent Morissette" >> "$tmpfile"
                echo "" >> "$tmpfile"
                cat "$file" >> "$tmpfile"
                mv "$tmpfile" "$file"
              fi
            fi
          done

      - name: Commit changes (if any)
        run: |
          git config user.name github-actions
          git config user.email github-actions@github.com
          git add .
          git diff --cached --quiet || git commit -m "chore: add SPDX license headers"
          git push

  # =========================
  # 🧹 LINT & AUTO-FIX
  # =========================
  
  
  lint:
    name: Lint & Auto-Fix
    runs-on: ubuntu-latest
    if: github.event_name == 'push' && !contains(github.event.head_commit.message, 'auto-fix lint')

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install Ruff
        run: pip install ruff

      - name: Auto-fix lint issues
        run: ruff check XMLExtractor-1.2 --fix

      - name: Format code
        run: ruff format XMLExtractor-1.2

      - name: Commit fixes
        run: |
          git config user.name github-actions
          git config user.email github-actions@github.com
          git add .
          git diff --cached --quiet || git commit -m "chore: auto-fix lint (ruff)"
          git push
  
  
  
  # =========================
  # 🤖 RELEASE PLEASE
  # =========================
  release-please:
    name: Release Please
    runs-on: ubuntu-latest
    needs: test
    if: github.event_name == 'push'

    steps:
      - name: Checkout (important)
        uses: actions/checkout@v6
        with:
          fetch-depth: 0   # 🔥 requis pour les tags

      
      - name: Run Release Please
        uses: googleapis/release-please-action@v4
        with:
          token: ${{ secrets.GITHUB_TOKEN }}